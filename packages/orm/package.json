{
  "name": "@qwreey-clickhouse/orm",
  "version": "1.0.2",
  "description": "Typescript based clickhouse client with automatic migration",
  "keywords": [
    "clickhouse",
    "orm",
    "typescript",
    "typebox"
  ],
  "homepage": "https://github.com/qwreey/clickhouse-orm#readme",
  "bugs": {
    "url": "https://github.com/qwreey/clickhouse-orm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwreey/clickhouse-orm.git"
  },
  "license": "MIT",
  "author": "me@qwreey.moe",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "../../node_modules/typescript/bin/tsc",
    "check": "npm run check:tsc && npm run check:eslint && npm run check:format",
    "check:tsc": "../../node_modules/typescript/bin/tsc --noemit",
    "check:eslint": "npm run --prefix ../../ check:eslint -- packages/orm/src",
    "check:format": "npm run --prefix ../../ prettier -- --check packages/orm/src",
    "fix:format": "npm run --prefix ../../ prettier -- --write packages/orm/src",
    "init": "npm ci --include-workspace-root --include=dev",
    "prepack": "npm run init && npm run check && npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.3",
    "@sinclair/typebox": "^0.34.49"
  }
}
